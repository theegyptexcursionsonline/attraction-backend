# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/attractions-network

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Foxes Passport SSO — the SHARED Foxes NEXTAUTH_SECRET, used ONLY to verify inbound
# single-sign-on assertions (aud=attraction). Distinct from JWT_SECRET. Leave unset to disable SSO.
FOXES_PASSPORT_SECRET=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=Attractions Network <noreply@yourdomain.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
# Privileged seed and QA credentials. Supply values only through the approved
# secret manager. Never commit real values.
TENANT_ADMIN_INITIAL_PASSWORD=
DELEGATE_DEFAULT_PASSWORD=
DEMO_ACCOUNT_PASSWORD=
SEED_SUPER_ADMIN_PASSWORD=
SEED_CUSTOMER_PASSWORD=
USER_NEW_PASSWORD=
