{
  "name": "attractions-network-backend",
  "version": "1.0.0",
  "description": "Express.js backend for Attractions Network Platform",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed": "ts-node src/scripts/seed.ts",
    "seed:promo": "ts-node src/scripts/seed-promo-codes.ts",
    "seed:availability": "ts-node src/scripts/seed-availability.ts",
    "audit:booking-integrity": "ts-node src/scripts/audit-booking-integrity.ts",
    "repair:booking-integrity": "ts-node src/scripts/repair-booking-integrity.ts",
    "rotate:tenant-payment-secrets": "ts-node src/scripts/rotate-tenant-payment-secrets.ts",
    "user:set-password": "ts-node src/scripts/set-user-password.ts",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:secrets": "node src/scripts/check-secret-hygiene.mjs",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.6",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.7.0",
    "mongoose": "^8.24.1",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "sanitize-html": "^2.13.1",
    "stripe": "^14.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.4",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.13.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
